---
# Copy to vault.yml and fill in your values
# Then encrypt: ansible-vault encrypt group_vars/vault.yml

# IKM (Initial Key Material) - used to regenerate keystores
vault_secp_ikm: "64_hex_chars"
vault_bls_ikm: "64_hex_chars"

# Wallet with MON for staking (min 100k MON) - fill when ready to register
vault_funded_wallet_private_key: ""
vault_beneficiary_address: "0x..."
vault_auth_address: ""

# Keystore password (generate with: openssl rand -base64 32)
vault_keystore_password: "YOUR_KEYSTORE_PASSWORD"

# Telegram alerts (optional)
vault_telegram_bot_token: ""
vault_telegram_chat_id: ""
