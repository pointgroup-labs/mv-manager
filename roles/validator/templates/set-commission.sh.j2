#!/bin/bash
# Set validator commission rate
# Generated by Ansible

set -e

VALIDATOR_ID="{{ validator_id | default('') }}"
RATE=${1:-{{ validator_commission_rate }}}

if [ -z "$VALIDATOR_ID" ]; then
    echo "ERROR: validator_id not set in inventory"
    exit 1
fi

source {{ monad_home }}/staking-sdk-cli/cli-venv/bin/activate
cd {{ monad_home }}/staking-sdk-cli

echo "Setting commission rate to ${RATE}%..."

python staking-cli/main.py change-commission \
  --validator-id $VALIDATOR_ID \
  --commission ${RATE} \
  --config-path config.toml

echo "Commission rate set to ${RATE}%!"
