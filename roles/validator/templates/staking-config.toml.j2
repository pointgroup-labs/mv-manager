title = "staking_cli"
rpc_url = "http://localhost:{{ monad_rpc_port }}"
chain_id = {{ monad_chain_id }}
contract_address = "0x0000000000000000000000000000000000001000"
log_level = "info"

[staking]
type = "local"
# Alternative: unset this and export FUNDED_ADDRESS_PRIVATE_KEY in the
# invoking task's environment: block (takes precedence, never hits disk).
funded_address_private_key = "{{ vault_funded_wallet_private_key | default('') }}"
commission_rate = {{ validator_commission_rate }}

[colors]
border = "white"
main = "red"
primary_text = "cyan"
secondary_text = "green"
highlight = "yellow"
