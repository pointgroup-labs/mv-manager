#!/bin/bash
set -e

LINES="${2:-100}"

case "${1:-consensus}" in
  consensus)
    tail -n "$LINES" -f {{ monad_logs_dir }}/{{ service_identifier }}.log
    ;;
  execution)
    tail -n "$LINES" -f {{ monad_home }}/execution/log/{{ execution_service_identifier }}.log
    ;;
  rpc)
    tail -n "$LINES" -f {{ monad_logs_dir }}/monad-rpc.log
    ;;
  all|*)
    journalctl -u {{ service_identifier }} -u {{ execution_service_identifier }} -u monad-rpc -n "$LINES" -f
    ;;
esac
