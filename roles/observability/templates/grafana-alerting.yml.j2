apiVersion: 1

contactPoints:
  - orgId: 1
    name: telegram
    receivers:
      - uid: telegram
        type: telegram
        settings:
          bottoken: "{{ vault_telegram_bot_token }}"
          chatid: "{{ vault_telegram_chat_id }}"
          parse_mode: Markdown

policies:
  - orgId: 1
    receiver: telegram
    group_by: ['alertname']
    group_wait: 30s
    group_interval: 5m
    repeat_interval: 4h
