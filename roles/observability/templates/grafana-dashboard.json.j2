    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "Monad node software version extracted from OTLP labels",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "text" },
          "noValue": "N/A"
        }
      },
      "gridPos": { "h": 3, "w": 4, "x": 20, "y": 1 },
      "id": 40,
      "options": {
        "colorMode": "background_solid",
        "graphMode": "none",
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "/^service_version$/"
        },
        "textMode": "auto"
      },
      "title": "Version",
      "type": "stat",
      "targets": [
        {
          "expr": "monad_total_uptime_us",
          "format": "table",
          "instant": true
        }
      ],
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true,
              "Value": true,
              "__name__": true,
              "env": true,
              "exported_job": true,
              "instance": true,
              "job": true,
              "network": true,
              "node_name": true,
              "otel_scope_name": true,
              "service_name": true
            }
          }
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "Current block height from RPC via custom exporter",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "noValue": "N/A",
          "thresholds": {
            "steps": [
