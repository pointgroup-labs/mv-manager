apiVersion: 1

groups:
  - orgId: 1
    name: monad
    folder: Monad
    interval: 1m
    rules:
      - uid: service-down
        title: ServiceDown
        condition: C
        for: 1m
        noDataState: Alerting
        labels:
          severity: critical
        annotations:
          summary: Monad service is down
        data:
          - refId: A
            datasourceUid: prometheus
            relativeTimeRange:
              from: 300
              to: 0
            model:
              refId: A
              expr: node_systemd_unit_state{name=~"monad-consensus\\.service|monad-execution\\.service", state="active"}
              intervalMs: 1000
              maxDataPoints: 43200
          - refId: B
            datasourceUid: '__expr__'
            relativeTimeRange:
              from: 0
              to: 0
            model:
              refId: B
              type: reduce
              expression: A
              reducer: last
              datasource:
                type: '__expr__'
                uid: '__expr__'
          - refId: C
            datasourceUid: '__expr__'
            relativeTimeRange:
              from: 0
              to: 0
            model:
              refId: C
              type: threshold
              expression: B
              conditions:
                - evaluator:
                    type: lt
                    params: [1]
              datasource:
                type: '__expr__'
                uid: '__expr__'

      - uid: disk-space-low
        title: DiskSpaceLow
        condition: C
        for: 5m
        noDataState: OK
        labels:
          severity: warning
        annotations:
          summary: "Disk usage above {{ alert_disk_threshold }}%"
        data:
          - refId: A
            datasourceUid: prometheus
            relativeTimeRange:
              from: 300
              to: 0
            model:
              refId: A
              expr: (1 - node_filesystem_avail_bytes{mountpoint="/"} / node_filesystem_size_bytes{mountpoint="/"}) * 100
              intervalMs: 1000
              maxDataPoints: 43200
          - refId: B
            datasourceUid: '__expr__'
            relativeTimeRange:
              from: 0
              to: 0
            model:
              refId: B
              type: reduce
              expression: A
              reducer: last
              datasource:
                type: '__expr__'
                uid: '__expr__'
          - refId: C
            datasourceUid: '__expr__'
            relativeTimeRange:
              from: 0
              to: 0
            model:
              refId: C
              type: threshold
              expression: B
              conditions:
                - evaluator:
                    type: gt
                    params: [{{ alert_disk_threshold }}]
              datasource:
                type: '__expr__'
                uid: '__expr__'

      - uid: high-memory
        title: HighMemoryUsage
        condition: C
        for: 10m
        noDataState: OK
        labels:
          severity: warning
        annotations:
          summary: Memory usage above 90%
        data:
          - refId: A
            datasourceUid: prometheus
            relativeTimeRange:
              from: 600
              to: 0
            model:
              refId: A
              expr: (1 - node_memory_MemAvailable_bytes / node_memory_MemTotal_bytes) * 100
              intervalMs: 1000
              maxDataPoints: 43200
          - refId: B
            datasourceUid: '__expr__'
            relativeTimeRange:
              from: 0
              to: 0
            model:
              refId: B
              type: reduce
              expression: A
              reducer: last
              datasource:
                type: '__expr__'
                uid: '__expr__'
          - refId: C
            datasourceUid: '__expr__'
            relativeTimeRange:
              from: 0
              to: 0
            model:
              refId: C
              type: threshold
              expression: B
              conditions:
                - evaluator:
                    type: gt
                    params: [90]
              datasource:
                type: '__expr__'
                uid: '__expr__'

      - uid: node-exporter-down
        title: NodeExporterDown
        condition: C
        for: 2m
        noDataState: Alerting
        labels:
          severity: critical
        annotations:
          summary: Node exporter is unreachable
        data:
          - refId: A
            datasourceUid: prometheus
            relativeTimeRange:
              from: 300
              to: 0
            model:
              refId: A
              expr: up{job="node-exporter"}
              intervalMs: 1000
              maxDataPoints: 43200
          - refId: B
            datasourceUid: '__expr__'
            relativeTimeRange:
              from: 0
              to: 0
            model:
              refId: B
              type: reduce
              expression: A
              reducer: last
              datasource:
                type: '__expr__'
                uid: '__expr__'
          - refId: C
            datasourceUid: '__expr__'
            relativeTimeRange:
              from: 0
              to: 0
            model:
              refId: C
              type: threshold
              expression: B
              conditions:
                - evaluator:
                    type: lt
                    params: [1]
              datasource:
                type: '__expr__'
                uid: '__expr__'

      - uid: otel-collector-down
        title: OtelCollectorDown
        condition: C
        for: 2m
        noDataState: Alerting
        labels:
          severity: critical
        annotations:
          summary: OTEL collector is unreachable (monad metrics lost)
        data:
          - refId: A
            datasourceUid: prometheus
            relativeTimeRange:
              from: 300
              to: 0
            model:
              refId: A
              expr: up{job="otel-monad"}
              intervalMs: 1000
              maxDataPoints: 43200
          - refId: B
            datasourceUid: '__expr__'
            relativeTimeRange:
              from: 0
              to: 0
            model:
              refId: B
              type: reduce
              expression: A
              reducer: last
              datasource:
                type: '__expr__'
                uid: '__expr__'
          - refId: C
            datasourceUid: '__expr__'
            relativeTimeRange:
              from: 0
              to: 0
            model:
              refId: C
              type: threshold
              expression: B
              conditions:
                - evaluator:
                    type: lt
                    params: [1]
              datasource:
                type: '__expr__'
                uid: '__expr__'

      - uid: voting-rate-low
        title: VotingRateLow
        condition: C
        for: 5m
        noDataState: OK
        labels:
          severity: critical
        annotations:
          summary: "Voting rate dropped below 80%"
        data:
          - refId: A
            datasourceUid: prometheus
            relativeTimeRange:
              from: 300
              to: 0
            model:
              refId: A
              expr: monad_voting_rate_pct
              intervalMs: 1000
              maxDataPoints: 43200
          - refId: B
            datasourceUid: '__expr__'
            relativeTimeRange:
              from: 0
              to: 0
            model:
              refId: B
              type: reduce
              expression: A
              reducer: last
              datasource:
                type: '__expr__'
                uid: '__expr__'
          - refId: C
            datasourceUid: '__expr__'
            relativeTimeRange:
              from: 0
              to: 0
            model:
              refId: C
              type: threshold
              expression: B
              conditions:
                - evaluator:
                    type: lt
                    params: [80]
              datasource:
                type: '__expr__'
                uid: '__expr__'

      - uid: node-out-of-sync
        title: NodeOutOfSync
        condition: C
        for: 5m
        noDataState: OK
        labels:
          severity: critical
        annotations:
          summary: Node is syncing (not fully synced)
        data:
          - refId: A
            datasourceUid: prometheus
            relativeTimeRange:
              from: 300
              to: 0
            model:
              refId: A
              expr: monad_sync_status
              intervalMs: 1000
              maxDataPoints: 43200
          - refId: B
            datasourceUid: '__expr__'
            relativeTimeRange:
              from: 0
              to: 0
            model:
              refId: B
              type: reduce
              expression: A
              reducer: last
              datasource:
                type: '__expr__'
                uid: '__expr__'
          - refId: C
            datasourceUid: '__expr__'
            relativeTimeRange:
              from: 0
              to: 0
            model:
              refId: C
              type: threshold
              expression: B
              conditions:
                - evaluator:
                    type: lt
                    params: [1]
              datasource:
                type: '__expr__'
                uid: '__expr__'

      - uid: low-wallet-balance
        title: LowWalletBalance
        condition: C
        for: 10m
        noDataState: OK
        labels:
          severity: warning
        annotations:
          summary: Wallet balance below 1 MON
        data:
          - refId: A
            datasourceUid: prometheus
            relativeTimeRange:
              from: 600
              to: 0
            model:
              refId: A
              expr: monad_wallet_balance_mon
              intervalMs: 1000
              maxDataPoints: 43200
          - refId: B
            datasourceUid: '__expr__'
            relativeTimeRange:
              from: 0
              to: 0
            model:
              refId: B
              type: reduce
              expression: A
              reducer: last
              datasource:
                type: '__expr__'
                uid: '__expr__'
          - refId: C
            datasourceUid: '__expr__'
            relativeTimeRange:
              from: 0
              to: 0
            model:
              refId: C
              type: threshold
              expression: B
              conditions:
                - evaluator:
                    type: lt
                    params: [1]
              datasource:
                type: '__expr__'
                uid: '__expr__'
